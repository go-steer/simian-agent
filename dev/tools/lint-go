# Run golangci-lint with the project's pinned config.
#
# Pass --fix to apply auto-fixable suggestions in place.
set -euo pipefail
. "$(dirname "$0")/common.sh"
cd "$(repo_root)"

# Pin the version that the project currently targets. Bump deliberately —
# new linter versions can surface findings that block CI.
GOLANGCI_LINT_VERSION="v2.12.1"
ensure_tool golangci-lint "github.com/golangci/golangci-lint/v2/cmd/golangci-lint@${GOLANGCI_LINT_VERSION}"

exec golangci-lint run \
  --config=dev/tools/.golangci.yml \
  "$@"
